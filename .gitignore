# Local environment and secrets
.env
.env.*
!.env.example
auth.json
*.env.txt
*.pem
*.key
*.p12
*.pfx

# Composer / PHP dependencies and local binaries
/vendor/
/composer.phar
/composer-setup.php

# Node dependencies and build caches
/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
/.npm/
/.yarn/
/.parcel-cache/

# Laravel runtime files
/storage/*.key
/storage/app/*
!/storage/app/.gitignore
!/storage/app/public/
/storage/app/public/*
!/storage/app/public/.gitignore
/storage/debugbar/*
!/storage/debugbar/.gitignore
/storage/framework/cache/*
!/storage/framework/cache/.gitignore
/storage/framework/sessions/*
!/storage/framework/sessions/.gitignore
/storage/framework/testing/*
!/storage/framework/testing/.gitignore
/storage/framework/views/*
!/storage/framework/views/.gitignore
/storage/logs/*
!/storage/logs/.gitignore
/bootstrap/cache/*
!/bootstrap/cache/.gitignore

# Public runtime/generated files
/public/hot
/public/storage/*
!/public/storage/.gitignore
/public/mix-manifest.json
/mix-manifest.json

# Logs, test output, and tool caches
*.log
error_log
.phpunit.result.cache
/.phpunit.cache/
.php-cs-fixer.cache
.pint.cache
/coverage/

# Local editor and agent files
/.idea/
/.vscode/
/.agents/
/.codex
